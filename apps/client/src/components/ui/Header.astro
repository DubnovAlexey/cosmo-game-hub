---
// Header component for global site navigation
// Компонент Header для глобальной навигации по сайту
---

<!-- Semantic header wrapper with Tailwind styling -->
<!-- Семантическая обертка шапки со стилями Tailwind -->
<header class="bg-gray-800 text-white shadow-md">

    <!-- Container with responsive flex direction (column on mobile, row on desktop) -->
    <!-- Контейнер с адаптивным направлением flex (колонка на мобильных, строка на десктопе) -->
    <div class="container mx-auto px-6 py-4 flex flex-col md:flex-row justify-between items-center gap-4">

        <!-- Site Logo/Title -->
        <!-- Логотип/Название сайта -->
        <a href="/" class="text-2xl font-bold text-blue-400 hover:text-blue-300 transition-colors text-center">
            Cosmo Game Hub
        </a>

        <!-- Main Navigation Menu -->
        <!-- Главное навигационное меню -->
        <nav class="w-full md:w-auto">
            <ul class="flex flex-wrap justify-center space-x-4 md:space-x-8 text-lg font-medium">
                <li>
                    <a href="/games" class="hover:text-blue-400 transition-colors">Games</a>
                </li>
                <li>
                    <a href="/leaderboard" class="hover:text-blue-400 transition-colors">Leaderboard</a>
                </li>
                <li>
                    <a href="/about" class="hover:text-blue-400 transition-colors">About</a>
                </li>
            </ul>
        </nav>

        <!-- User Authentication Actions -->
        <!-- Действия аутентификации пользователя -->
        <div class="w-full md:w-auto flex justify-center">
            <button class="bg-blue-600 hover:bg-blue-700 px-8 py-2 rounded-lg font-semibold transition-colors w-full md:w-auto">
                Login
            </button>
        </div>

    </div>
</header>