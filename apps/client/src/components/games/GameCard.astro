---
// Define the shape of the component properties using TypeScript
// Определяем структуру свойств компонента с помощью TypeScript
interface Props {
    title: string;
    description: string;
    badge?: string; // The '?' means this property is optional (необязательное свойство)
    gameUrl: string;
}

// Destructure the properties from Astro.props
// Деструктуризируем свойства из Astro.props
const { title, description, badge, gameUrl } = Astro.props;
---

<!-- Article tag represents an independent, self-contained piece of content -->
<!-- Тег article представляет собой независимый, самодостаточный блок контента -->
<article class="bg-gray-800 rounded-xl overflow-hidden shadow-lg hover:shadow-blue-500/20 transition-all duration-300 flex flex-col border border-gray-700 hover:border-blue-500">

    <!-- Placeholder for the game image -->
    <!-- Заглушка для изображения игры -->
    <div class="h-48 bg-gray-700 flex items-center justify-center relative">
        <span class="text-gray-500 font-medium">Image Placeholder</span>

		<!-- Render the badge conditionally if it exists -->
	    <!-- Рендерим бейдж условно, если он существует -->
        {badge && (
				<span class="absolute top-4 right-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                {badge}
            </span>
        )}
    </div>

    <!-- Container for card text and actions -->
    <!-- Контейнер для текста карточки и действий -->
    <div class="p-6 flex flex-col flex-grow">

        <!-- Game Title -->
        <!-- Название игры -->
        <h3 class="text-2xl font-bold text-white mb-2">{title}</h3>

        <!-- Game Description -->
        <!-- Описание игры -->
        <p class="text-gray-400 mb-6 flex-grow">
            {description}
        </p>

        <!-- Action Button -->
        <!-- Кнопка действия -->
        <a href={gameUrl} class="block w-full text-center bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 px-4 rounded-lg transition-colors">
            Play Now
        </a>

    </div>
</article>