---
// [EN] Import the global Layout component (Импорт зе глобал лейаут компонент)
// [RU] Импортируем глобальный компонент макета Layout
import Layout from '@layouts/Layout.astro';

// [EN] Import our new React component for the chess game (Импорт ауэр нью реакт компонент)
// [RU] Импортируем наш новый React-компонент для шахматной игры
import { ChessGame } from '../../components/games/chess/ChessGame';
---

<!--
  [EN] Render the global Layout with standard title (Рендер зе глобал лейаут)
  [RU] Отрисовываем глобальный макет со стандартным заголовком
-->
<Layout title="Play Chess | Cosmo Game Hub">

    <!--
      [EN] Main container with flexbox for centered alignment (Мейн контейнер виз флексбокс)
      [RU] Главный контейнер с flexbox для выравнивания по центру
    -->
    <main class="container mx-auto px-4 py-8 flex flex-col items-center justify-center min-h-[80vh]">

        <h1 class="text-4xl font-bold text-white mb-8 tracking-wider uppercase">
            Chess
        </h1>

		<!--
          [EN] Injecting React component with highest Hydration priority (Инджектинг реакт компонент)
          [RU] Внедряем React-компонент с высшим приоритетом гидратации (client:load)
        -->
        <div class="w-full max-w-6xl">
            <ChessGame client:load />
        </div>

    </main>

</Layout>