---
// Import the base Layout component using a Path Alias
// Импортируем базовый компонент Layout, используя псевдоним пути (Path Alias)
import Layout from '@layouts/Layout.astro';
---

<!-- We use the Layout component and pass the "title" Prop -->
<!-- Мы используем компонент Layout и передаем Prop "title" -->
<Layout title="Home | Cosmo Game Hub">

    <!-- Main container for the landing page -->
    <!-- Главный контейнер для посадочной страницы -->
    <div class="flex flex-col items-center justify-center min-h-[80vh] text-center">

        <!-- Main Heading -->
        <!-- Главный заголовок -->
        <h1 class="text-5xl font-bold mb-6 text-blue-400">
            Welcome to Cosmo Game Hub
        </h1>

        <!-- Subtitle -->
        <!-- Подзаголовок -->
        <p class="text-xl text-gray-300 mb-8 max-w-2xl">
            Your ultimate platform for playing, learning, and competing in classic logic games.
        </p>

        <!-- Call to Action Button -->
        <!-- Кнопка призыва к действию -->
        <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-lg transition-colors">
            Start Playing
        </button>

    </div>

</Layout>