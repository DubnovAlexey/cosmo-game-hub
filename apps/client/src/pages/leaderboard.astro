---
// Import the global Layout component
// Импортируем глобальный компонент Layout
import Layout from '@layouts/Layout.astro';

// Import our mock data
// Импортируем наши тестовые данные
import { leaderboardData } from '@utils/mockLeaderboard';
---

<Layout title="Leaderboard | Cosmo Game Hub">

    <div class="container mx-auto px-6 py-12">

        <h1 class="text-4xl font-bold text-blue-400 mb-8 text-center">
            Top Players
        </h1>

        <div class="overflow-x-auto bg-gray-800 rounded-xl shadow-lg border border-gray-700">

            <table class="w-full text-left border-collapse">

                <!-- Table Header -->
                <!-- Шапка таблицы -->
                <thead>
                    <tr class="bg-gray-900 text-blue-400 border-b border-gray-700 text-sm uppercase tracking-wider">
                        <th class="p-4 font-semibold">Rank</th>
                        <th class="p-4 font-semibold">Player</th>
                        <th class="p-4 font-semibold">Score</th>
                        <th class="p-4 font-semibold">Game</th>
                    </tr>
                </thead>

                <!-- Table Body with Dynamic Rendering and Zebra Striping -->
                <!-- Тело таблицы с динамическим рендерингом и чересполосицей -->
                <!-- NOTE: No HTML comments are allowed inside the curly braces below! -->
                <!-- ПРИМЕЧАНИЕ: Внутри фигурных скобок ниже не должно быть HTML-комментариев! -->
                <tbody class="text-gray-300">

                    {leaderboardData.map((player) => (
							<tr class="border-b border-gray-700 hover:bg-gray-700/50 even:bg-gray-700/30 transition-colors">
                            <td class={`p-4 font-bold ${player.rankColor}`}>
                                #{player.rank}
                            </td>
                            <td class="p-4 font-medium text-white">
                                {player.username}
                            </td>
                            <td class="p-4 font-mono text-blue-300">
                                {player.score}
                            </td>
                            <td class="p-4">
                                {player.game}
                            </td>
                        </tr>
                    ))}

                </tbody>
            </table>
        </div>

    </div>

</Layout>