---
// Import the global Layout component using Path Alias
// Импортируем глобальный компонент Layout, используя псевдоним пути
import Layout from '@layouts/Layout.astro';

// Import the GameCard component
// Импортируем компонент GameCard
import GameCard from '@components/games/GameCard.astro';

// Import our mock database
// Импортируем нашу базу данных-заглушку
import { games } from '@utils/mockGames';
---

<Layout title="Games | Cosmo Game Hub">

    <div class="container mx-auto px-6 py-12">

        <h1 class="text-4xl font-bold text-blue-400 mb-8 text-center">
            Our Games Collection
        </h1>

		<!-- CSS Grid container for responsive card layout -->
	    <!-- Контейнер CSS Grid для адаптивной сетки карточек -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <!-- Map through the games array and render a GameCard for each -->
            <!-- Проходим по массиву игр и рендерим GameCard для каждой -->
			{games.map((game) => (
				<GameCard
					title={game.title}
			        description={game.description}
			        badge={game.badge}
			        gameUrl={game.gameUrl}
				/>
			))}

            <!-- Future Game Placeholder -->
            <!-- Карточка-заглушка для будущих игр -->
            <article class="bg-gray-800/50 rounded-xl border-2 border-dashed border-gray-700 flex flex-col items-center justify-center p-6 text-center opacity-70">
                <h3 class="text-xl font-bold text-gray-400">Coming Soon</h3>
                <p class="text-gray-500 mt-2">More classic logic games are on the way!</p>
            </article>

        </div>

    </div>

</Layout>